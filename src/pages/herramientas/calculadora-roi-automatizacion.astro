---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Breadcrumbs from '../../components/Breadcrumbs.astro'
import RoiCalculator from '../../components/RoiCalculator.jsx'
import CTA from '../../components/CTA.astro'
import { SITE } from '../../data/site'

const canonical = `${SITE.url}/herramientas/calculadora-roi-automatizacion/`
const description = 'Calcula horas recuperables, ahorro anual y tiempo estimado de recuperación para un proyecto de automatización empresarial.'
const hasParameters = Astro.url.search.length > 0
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Calculadora ROI de automatización',
  description,
  url: canonical,
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'GTQ' },
  provider: { '@id': `${SITE.url}/#organization` },
}
---

<BaseLayout title="Calculadora ROI de automatización | WavDev" description={description} canonical={canonical} schema={schema} noindex={hasParameters}>
  <header class="service-hero roi-hero">
    <div class="container">
      <Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Herramientas' }, { label: 'Calculadora ROI' }]} />
      <span class="eyebrow">Herramienta gratuita</span>
      <h1>Calculadora ROI de automatización</h1>
      <p class="lead">Estima cuánto tiempo y dinero podría recuperar tu empresa al automatizar una tarea repetitiva. El cálculo ocurre en tu navegador y no envía los datos ingresados a WavDev.</p>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <RoiCalculator client:load />
    </div>
  </section>

  <section class="section related-section">
    <div class="container split">
      <article class="prose">
        <span class="eyebrow">Metodología</span>
        <h2>Cómo se calcula el retorno</h2>
        <p>Las horas recuperables se estiman multiplicando personas, horas semanales, 4.33 semanas por mes y porcentaje automatizable. El ahorro de tiempo utiliza el costo por hora y se suma al costo evitable de errores.</p>
        <p>El tiempo de recuperación divide la inversión inicial entre el ahorro mensual. Los escenarios ajustan la recuperación de horas para reflejar que una implementación rara vez alcanza su potencial completo desde el primer día.</p>
        <a class="button button-secondary" href="/downloads/plantilla-levantamiento-procesos.csv" download data-download="process-template">Descargar plantilla de levantamiento</a>
      </article>
      <aside class="card card-body">
        <span class="eyebrow">Antes de decidir</span>
        <h2 class="aside-title">Valida los supuestos</h2>
        <ul class="check-list">
          <li>Mide el proceso actual durante varias semanas.</li>
          <li>Separa tiempo productivo de esperas y correcciones.</li>
          <li>Incluye adopción, soporte y costos de proveedores.</li>
          <li>Define cómo comprobarás el resultado después del lanzamiento.</li>
        </ul>
      </aside>
    </div>
  </section>
  <CTA service="automatización de procesos" />
</BaseLayout>
