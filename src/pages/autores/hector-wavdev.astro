---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import Breadcrumbs from '../../components/Breadcrumbs.astro'
import CTA from '../../components/CTA.astro'
import { AUTHOR } from '../../data/authority'
import { SITE } from '../../data/site'

const resources = (await getCollection('resources', ({ data }) => !data.draft)).sort((a, b) => b.data.updatedDate.valueOf() - a.data.updatedDate.valueOf())
const canonical = `${SITE.url}${AUTHOR.profileUrl}`
const description = 'Perfil de Héctor, responsable técnico de WavDev y autor de contenidos sobre software empresarial, CRM, automatización y desarrollo web.'
const schema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  mainEntity: {
    '@type': 'Person',
    '@id': `${canonical}#person`,
    name: AUTHOR.name,
    jobTitle: AUTHOR.role,
    url: canonical,
    sameAs: [AUTHOR.linkedin],
    worksFor: { '@id': `${SITE.url}/#organization` },
    knowsAbout: AUTHOR.specialties,
  },
}
---

<BaseLayout title="Héctor, responsable técnico de WavDev" description={description} canonical={canonical} schema={schema}>
  <header class="service-hero author-hero">
    <div class="container">
      <Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Autores' }, { label: 'Héctor' }]} />
      <span class="eyebrow">Autor y responsable técnico</span>
      <h1>Héctor, WavDev</h1>
      <p class="lead">Diseña y revisa soluciones de software empresarial con énfasis en procesos, integraciones, seguridad, medición y adopción por usuarios reales.</p>
      <a class="button button-secondary" href={AUTHOR.linkedin} target="_blank" rel="noopener noreferrer">Ver perfil profesional</a>
    </div>
  </header>

  <section class="section">
    <div class="container split">
      <article class="prose">
        <h2>Áreas de trabajo</h2>
        <p>Su trabajo en WavDev comienza por entender el problema empresarial antes de elegir tecnología. Participa en el diagnóstico, definición de alcance, arquitectura, revisión técnica y medición posterior al lanzamiento.</p>
        <p>Los contenidos publicados bajo este perfil explican criterios que WavDev utiliza al evaluar sistemas, CRM, automatizaciones, integraciones y proyectos web. Cuando una afirmación depende de un proveedor o estándar externo, la guía enlaza fuentes verificables.</p>
        <h2>Principios editoriales</h2>
        <ul>
          <li>No atribuir resultados sin evidencia autorizada.</li>
          <li>Distinguir estimaciones de precios o retornos garantizados.</li>
          <li>Actualizar fechas únicamente cuando cambia el contenido.</li>
          <li>Explicar riesgos, límites y alternativas.</li>
        </ul>
      </article>
      <aside class="card card-body">
        <span class="eyebrow">Especialidades</span>
        <ul class="check-list">
          {AUTHOR.specialties.map((specialty) => <li>{specialty}</li>)}
        </ul>
      </aside>
    </div>
  </section>

  <section class="section related-section">
    <div class="container">
      <span class="eyebrow">Contenido revisado</span>
      <h2>Guías recientes</h2>
      <div class="grid grid-3">
        {resources.slice(0, 6).map((entry) => (
          <a class="card card-body related-link" href={`/recursos/${entry.data.slug}/`}>
            <span>{entry.data.category}</span>
            <strong>{entry.data.title}</strong>
          </a>
        ))}
      </div>
    </div>
  </section>
  <CTA />
</BaseLayout>
